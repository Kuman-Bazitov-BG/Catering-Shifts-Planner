{
  "name": "catering-shifts-planner",
  "version": "1.0.0",
  "private": true,
  "description": "Shifts Planner app: Next.js + React + Expo ",
  "homepage": "https://github.com/Kuman-Bazitov-BG/Catering-Shifts-Planner#readme",
  "bugs": {
    "url": "https://github.com/Kuman-Bazitov-BG/Catering-Shifts-Planner/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kuman-Bazitov-BG/Catering-Shifts-Planner.git"
  },
  "license": "ISC",
  "author": "Kuman Bazitov",
  "workspaces": [
    "catering-web",
    "cetaring-shifts-planner-mobile"
  ],
  "scripts": {
    "dev": "concurrently -n web,mobile -c cyan,magenta \"npm run dev -w catering-web\" \"npm run start --prefix cetaring-shifts-planner-mobile\"",
