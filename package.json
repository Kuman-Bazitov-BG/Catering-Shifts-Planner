    "dev:mobile": "npm run start --prefix cetaring-shifts-planner-mobile",
    "build": "npm run build -w catering-web",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
